{
  "cinematic": {
    "prefix": "cinematic",
    "body": [
      "cinematic \"${1:Name}\" {",
      "  layer ${2:main} {",
      "    fn: ${3:circle(0.3)} | ${4:glow(2.0)}",
      "  }",
      "}"
    ],
    "description": "Full cinematic block with a layer"
  },
  "layer": {
    "prefix": "layer",
    "body": [
      "layer ${1:name} {",
      "  fn: ${2:circle(0.3)} | ${3:glow(2.0)}",
      "}"
    ],
    "description": "Layer block with generative function"
  },
  "define": {
    "prefix": "define",
    "body": [
      "define ${1:name}(${2:params}) {",
      "  ${3:circle($2)} | ${4:glow(2.0)}",
      "}"
    ],
    "description": "Define a reusable generative function"
  },
  "arc": {
    "prefix": "arc",
    "body": [
      "arc {",
      "  0:00 \"${1:start}\" {",
      "    ${2:param}: ${3:0.0}",
      "  }",
      "",
      "  ${4:0:05} \"${5:build}\" {",
      "    ${2:param} -> ${6:1.0} ease(${7:expo_out}) over ${8:3}s",
      "  }",
      "}"
    ],
    "description": "Arc timeline block with moments"
  },
  "react": {
    "prefix": "react",
    "body": [
      "react {",
      "  ${1:mouse.click} -> ${2:particles.burst}(",
      "    at: ${3:mouse.world},",
      "    count: ${4:200},",
      "    color: ${5:white}",
      "  )",
      "}"
    ],
    "description": "React block for interaction bindings"
  },
  "resonate": {
    "prefix": "resonate",
    "body": [
      "resonate {",
      "  ${1:a.param} ~ ${2:b.param} * ${3:0.5}",
      "  ${4:b.param} ~ ${5:a.param} * ${6:-0.5}",
      "  damping: ${7:0.95}",
      "}"
    ],
    "description": "Resonate block for cross-layer feedback"
  },
  "lens-flat": {
    "prefix": "lens-flat",
    "body": [
      "lens ${1:main} {",
      "  mode: flat",
      "  fields: [${2:layer_name}]",
      "  post: [${3:bloom(1.0)}, ${4:vignette(0.3)}]",
      "}"
    ],
    "description": "Flat (2D fragment shader) lens configuration"
  },
  "lens-raymarch": {
    "prefix": "lens-raymarch",
    "body": [
      "lens ${1:main} {",
      "  mode: raymarch",
      "  fields: [${2:terrain}]",
      "  camera: orbit(radius: ${3:4.0}, height: ${4:2.0}, speed: ${5:0.05})",
      "  lighting: sun([0.5, 0.8, 1.0], 0.8) + ambient(0.15)",
      "  post: [bloom(${6:1.2}), vignette(${7:0.3})]",
      "}"
    ],
    "description": "Raymarch (3D) lens configuration"
  },
  "param-audio": {
    "prefix": "param-audio",
    "body": [
      "${1:param}: ${2:0.0} ~ audio.${3|bass,mid,treble,energy,beat|} * ${4:1.0}"
    ],
    "description": "Audio-reactive parameter with modulation"
  },
  "param-data": {
    "prefix": "param-data",
    "body": [
      "${1:param}: ${2:0.0} ~ data.${3:value} * ${4:1.0}"
    ],
    "description": "Data-driven parameter with modulation"
  },
  "param-mouse": {
    "prefix": "param-mouse",
    "body": [
      "${1:param}: ${2:0.0} ~ mouse.${3|x,y,click,velocity|} * ${4:1.0}"
    ],
    "description": "Mouse-reactive parameter with modulation"
  },
  "listen": {
    "prefix": "listen",
    "body": [
      "listen {",
      "  source: ${1|mic,file,stream|}",
      "  fft: ${2:1024}",
      "  smoothing: ${3:0.8}",
      "  ${4:# frequency bands are auto-mapped to audio.bass/mid/treble}",
      "}"
    ],
    "description": "Listen block for audio input configuration"
  },
  "voice": {
    "prefix": "voice",
    "body": [
      "voice {",
      "  source: ${1:mic}",
      "  threshold: ${2:0.1}",
      "  ${3:param}: ${4:0.0} ~ audio.energy * ${5:1.0}",
      "}"
    ],
    "description": "Voice block for voice/audio input processing"
  },
  "score": {
    "prefix": "score",
    "body": [
      "score {",
      "  bpm: ${1:120}",
      "  time_signature: ${2:4}/${3:4}",
      "  ",
      "  ${4:1}:${5:1} {",
      "    ${6:intensity}: ${7:0.0} -> ${8:1.0} ease(${9:expo_out})",
      "  }",
      "}"
    ],
    "description": "Score block for musical timing and synchronization"
  },
  "gravity": {
    "prefix": "gravity",
    "body": [
      "gravity {",
      "  strength: ${1:9.8}",
      "  direction: [${2:0.0}, ${3:-1.0}]",
      "  damping: ${4:0.98}",
      "  ${5:# affects all particle systems in scope}",
      "}"
    ],
    "description": "Gravity simulation block"
  },
  "breed": {
    "prefix": "breed",
    "body": [
      "breed {",
      "  population: ${1:50}",
      "  generations: ${2:100}",
      "  mutation: ${3:0.1}",
      "  fitness: ${4:symmetry}",
      "  ",
      "  fn: ${5:circle(radius)} | ${6:glow(intensity)}",
      "}"
    ],
    "description": "Breed block for evolutionary/generative exploration"
  },
  "project": {
    "prefix": "project",
    "body": [
      "project {",
      "  name: \"${1:my-project}\"",
      "  resolution: [${2:1920}, ${3:1080}]",
      "  fps: ${4:60}",
      "}"
    ],
    "description": "Project settings and metadata"
  },
  "memory": {
    "prefix": "memory",
    "body": [
      "layer ${1:name} {",
      "  memory: [${2:prev_value}]",
      "  fn: ${3:circle(0.3)} | glow(${2:prev_value} * ${4:2.0})",
      "  ${2:prev_value}: ${5:fn * 0.95}",
      "}"
    ],
    "description": "Layer with persistent memory (values survive across frames)"
  },
  "cast": {
    "prefix": "cast",
    "body": [
      "layer ${1:emitter} {",
      "  cast: [${2:brightness}]",
      "  fn: ${3:circle(0.3)} | glow(2.0)",
      "  ${2:brightness}: ${4:fn}",
      "}",
      "",
      "layer ${5:receiver} {",
      "  fn: ${6:ring(0.4, 0.02)} | glow(${1:emitter}.${2:brightness} * ${7:1.5})",
      "}"
    ],
    "description": "Layer with cast (broadcast values to other layers)"
  },
  "temporal": {
    "prefix": "temporal",
    "body": [
      "${1:param}: ${2:0.0} -> ${3:1.0} ease(${4|expo_out,expo_in,smooth,cubic_in_out,linear,elastic,bounce|}) over ${5:3}s"
    ],
    "description": "Parameter with temporal transition (eased over duration)"
  },
  "data-component": {
    "prefix": "data-component",
    "body": [
      "# Data-driven component",
      "# Attributes: progress, label",
      "",
      "cinematic \"${1:DataVis}\" {",
      "  layer bg {",
      "    fn: fbm(scale: 3.0, octaves: 3.0) | shade(0.05, 0.05, 0.1)",
      "  }",
      "",
      "  layer indicator {",
      "    fn: ring(radius: 0.35, width: 0.03) | mask_arc(data.progress * tau) | shade(${2:0.4}, ${3:0.8}, ${4:1.0}) | glow(1.5)",
      "  }",
      "",
      "  layer value {",
      "    fn: circle(0.08) | shade(1.0, 1.0, 1.0) | glow(data.progress * 3.0)",
      "  }",
      "",
      "  resonate {",
      "    indicator.radius ~ value.intensity * 0.1",
      "    damping: 0.92",
      "  }",
      "",
      "  lens main {",
      "    mode: flat",
      "    fields: [bg, indicator, value]",
      "    post: [bloom(0.3, 1.5), vignette(0.4)]",
      "  }",
      "}"
    ],
    "description": "Data-driven component template with progress indicator"
  },
  "audio-reactive": {
    "prefix": "audio-reactive",
    "body": [
      "# Audio-reactive visualization",
      "",
      "cinematic \"${1:AudioVis}\" {",
      "  layer bass_ring {",
      "    fn: ring(radius: 0.2, width: 0.03) | glow(2.0)",
      "    radius: 0.2 ~ audio.bass * 0.3",
      "    color: ember",
      "  }",
      "",
      "  layer mid_field {",
      "    fn: fbm(scale: 3.0, octaves: 4.0) | shade(0.3, 0.5, 0.8)",
      "    scale: 3.0 ~ audio.mid * 2.0",
      "    opacity: 0.6 ~ audio.energy * 0.4",
      "  }",
      "",
      "  layer treble_stars {",
      "    fn: star(points: 5.0, radius: 0.05, inner: 0.02) | repeat(8.0) | glow(1.5)",
      "    radius: 0.05 ~ audio.treble * 0.1",
      "    color: cyan",
      "  }",
      "",
      "  resonate {",
      "    bass_ring.radius ~ mid_field.scale * 0.05",
      "    treble_stars.radius ~ bass_ring.radius * -0.2",
      "    damping: 0.9",
      "  }",
      "",
      "  lens main {",
      "    mode: flat",
      "    fields: [mid_field, bass_ring, treble_stars]",
      "    post: [bloom(0.2, 2.0), chromatic(0.003), vignette(0.5)]",
      "  }",
      "}"
    ],
    "description": "Audio-reactive component with bass/mid/treble layers"
  },
  "post-chain": {
    "prefix": "post-chain",
    "body": [
      "post: [bloom(${1:0.3}, ${2:1.5}), vignette(${3:0.4}), chromatic(${4:0.003})]"
    ],
    "description": "Post-processing chain: bloom + vignette + chromatic aberration"
  },
  "import-stdlib": {
    "prefix": "import-stdlib",
    "body": [
      "import \"${1:stdlib/${2:shapes}.game}\" expose ${3:name1}, ${4:name2}"
    ],
    "description": "Import definitions from standard library"
  },
  "fn-pipeline": {
    "prefix": "fn-pipeline",
    "body": [
      "fn: ${1:circle(0.3)} | ${2:domain_warp(0.1, 3.0)} | ${3:shade(1.0, 1.0, 1.0)} | ${4:glow(2.0)}"
    ],
    "description": "Generative function pipeline: shape | transform | color | effect"
  },
  "layer-full": {
    "prefix": "layer-full",
    "body": [
      "layer ${1:name} {",
      "  fn: ${2:circle(0.3)} | ${3:glow(2.0)}",
      "  opacity: ${4:1.0}",
      "  ${5:param}: ${6:0.0} ~ ${7:audio.bass} * ${8:1.0}",
      "}"
    ],
    "description": "Layer with opacity and audio-reactive parameter"
  },
  "transition": {
    "prefix": "transition",
    "body": [
      "${1:param} -> ${2:1.0} ease(${3|expo_out,expo_in,smooth,cubic_in_out,linear,elastic,bounce|}) over ${4:3}s"
    ],
    "description": "Animated transition with easing"
  },
  "modulation": {
    "prefix": "modulation",
    "body": [
      "${1:param}: ${2:0.5} ~ ${3|audio.bass,audio.mid,audio.treble,audio.energy,audio.beat,mouse.x,mouse.y,time|} * ${4:0.5}"
    ],
    "description": "Parameter with signal modulation"
  }
}
