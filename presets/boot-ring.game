# Boot Ring — gold ring filling with progress, breathing glow
# Usage: <game-boot-ring progress="0.5"></game-boot-ring>
# API:   el.progress = 0.0..1.0

cinematic "Boot Ring" {
  layer track {
    fn: ring(0.3, 0.015) | glow(1.0) | tint(charcoal)
  }
  layer fill {
    fn: ring(0.3, 0.025) | mask_arc(fill_angle) | glow(glow_str) | tint(gold)
    fill_angle: 0.0 ~ data.progress * 6.283
    glow_str: 2.0 ~ 2.0 + sin(time * 2.0) * 0.5
  }
}
