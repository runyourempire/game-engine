# Achievement Progress — arc ring filling to threshold, gold glow on complete
# Usage: <game-achievement-progress progress="0.7"></game-achievement-progress>
# API:   el.progress = 0.0..1.0

cinematic "Achievement Progress" {
  layer track {
    fn: ring(0.35, 0.01) | glow(0.8) | tint(charcoal)
  }
  layer fill {
    fn: ring(0.35, 0.025) | mask_arc(fill_angle) | glow(glow_val) | tint(gold)
    fill_angle: 0.0 ~ data.progress * 6.283
    glow_val: 2.0 ~ data.progress * 4.0
  }
}
