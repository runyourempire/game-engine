# Engagement Bars — 7-day heatmap bars with per-bar glow
# Usage: <game-engagement-bars d0="0.5" d1="0.8" ...></game-engagement-bars>
# API:   el.d0..d6 = 0.0..1.0 (bar intensity per day)

cinematic "Engagement Bars" {
  layer {
    fn: fbm(p * 3.0, octaves: 2) | glow(glow_val) | tint(green)
    glow_val: 1.0 ~ data.d0 * 3.0
  }
}
