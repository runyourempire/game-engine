// Achievement Progress — circular progress ring with track and fill arc.
// fill_angle drives arc sweep, glow_val controls fill brightness.

cinematic "achievement-progress" {
  layer config {
    charcoal: 0.3
    fill_angle: 0.0
    glow_val: 2.0
    gold: 0.83
  }

  layer track {
    ring(0.35, 0.01) | glow(0.8) | tint(charcoal, charcoal, charcoal)
  }

  layer fill {
    ring(0.35, 0.025) | mask_arc(fill_angle) | glow(glow_val) | tint(gold, 0.69, 0.22)
  }
}
